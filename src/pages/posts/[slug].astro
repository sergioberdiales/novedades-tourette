---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const base = import.meta.env.BASE_URL;
const canonicalPath = `${import.meta.env.BASE_URL}posts/${post.slug}/`;
const shareUrl = Astro.site ? new URL(canonicalPath, Astro.site).toString() : canonicalPath;
const shareText = encodeURIComponent(post.data.title);
const encodedUrl = encodeURIComponent(shareUrl);
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("es-ES", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  }).format(date);
---

<BaseLayout title={`${post.data.title} | Novedades Tourette`} description={post.data.excerpt}>
  <header class="site-header">
    <a class="brand-lockup" href={base} aria-label="Novedades Tourette, inicio">
      <span class="brand-mark" aria-hidden="true">N</span>
      <span>
        <strong>Novedades Tourette</strong>
        <small>Boletín informativo</small>
      </span>
    </a>
    <nav class="nav-menu" aria-label="Navegación principal">
      <a href={base}>Inicio</a>
      <a href={`${base}#fichas`}>Fichas</a>
      <a href={`${base}#fuentes`}>Fuentes</a>
      <a href={`${base}#proyecto`}>Sobre el proyecto</a>
    </nav>
    <a class="context-link" href="https://touretteasturias.org/">
      <span aria-hidden="true"></span>
      En el entorno de APASTTA
    </a>
  </header>

  <main id="contenido" class="post-page">
    <article class="post-detail">
      <a class="back-link" href={`${base}#fichas`}>Volver al listado</a>
      <p class="eyebrow">{post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p class="lead">{post.data.excerpt}</p>

      <dl class="post-facts">
        <div>
          <dt>Fecha</dt>
          <dd><time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time></dd>
        </div>
        <div>
          <dt>Fuente</dt>
          <dd>{post.data.source}</dd>
        </div>
        <div>
          <dt>Tipo de fuente</dt>
          <dd>{post.data.sourceType}</dd>
        </div>
        <div>
          <dt>Nivel de lectura</dt>
          <dd>{post.data.evidenceLevel}</dd>
        </div>
        <div>
          <dt>Enlace original</dt>
          <dd><a href={post.data.originalUrl}>{post.data.originalUrl}</a></dd>
        </div>
        <div>
          <dt>Idioma original</dt>
          <dd>{post.data.originalLanguage}</dd>
        </div>
        <div>
          <dt>Puede interesar a</dt>
          <dd>{post.data.audience.join(" · ")}</dd>
        </div>
        <div>
          <dt>Fecha de revisión</dt>
          <dd><time datetime={post.data.checkedDate.toISOString()}>{formatDate(post.data.checkedDate)}</time></dd>
        </div>
        <div>
          <dt>Etiquetas</dt>
          <dd class="tag-list">{post.data.tags.map((tag) => <span>{tag}</span>)}</dd>
        </div>
      </dl>

      <section class="content-section">
        <h2>Resumen en español</h2>
        <p>{post.data.summary}</p>
        <Content />
      </section>

      <section class="content-section relevance">
        <h2>Por qué puede ser relevante</h2>
        <p>{post.data.relevance}</p>
      </section>

      <p class="medical-note" role="note">
        Prudencia médica: {post.data.caution}
      </p>

      <section class="share-panel" aria-labelledby="share-title">
        <h2 id="share-title">Compartir ficha</h2>
        <div class="share-actions">
          <a href={`https://wa.me/?text=${shareText}%20${encodedUrl}`}>WhatsApp</a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}>Facebook</a>
          <a href={`https://twitter.com/intent/tweet?text=${shareText}&url=${encodedUrl}`}>X/Twitter</a>
          <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}>LinkedIn</a>
          <button type="button" data-copy-link={shareUrl}>Copiar enlace</button>
        </div>
        <p class="copy-status" aria-live="polite" data-copy-status></p>
      </section>
    </article>
  </main>

  <footer class="site-footer">
    <div class="footer-brand">
      <span class="brand-mark" aria-hidden="true">N</span>
      <div>
        <strong>Novedades Tourette</strong>
        <p>Prototipo personal de boletín informativo en el entorno de APASTTA.</p>
      </div>
    </div>
    <nav aria-label="Enlaces del pie">
      <p class="eyebrow">Enlaces</p>
      <a href={base}>Inicio</a>
      <a href={`${base}#fichas`}>Fichas</a>
      <a href={`${base}#fuentes`}>Fuentes</a>
    </nav>
    <div>
      <p class="eyebrow">Aviso</p>
      <p>Contenido informativo. No sustituye la valoración de profesionales sanitarios.</p>
    </div>
  </footer>

  <script is:inline src={`${base}share.js`}></script>
</BaseLayout>
