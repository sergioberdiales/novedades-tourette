---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const canonicalPath = `${import.meta.env.BASE_URL}posts/${post.slug}/`;
const shareUrl = `${Astro.site ?? ""}${canonicalPath}`;
const shareText = encodeURIComponent(post.data.title);
const encodedUrl = encodeURIComponent(shareUrl);
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("es-ES", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  }).format(date);
---

<BaseLayout title={`${post.data.title} | Novedades Tourette`} description={post.data.excerpt}>
  <header class="compact-header">
    <nav class="topbar" aria-label="Navegación principal">
      <a class="brand" href={import.meta.env.BASE_URL}>Novedades Tourette</a>
      <a class="nav-link" href={`${import.meta.env.BASE_URL}`}>Todas las fichas</a>
    </nav>
  </header>

  <main id="contenido" class="post-page">
    <article class="post-detail">
      <a class="back-link" href={import.meta.env.BASE_URL}>Volver al listado</a>
      <p class="eyebrow">{post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p class="lead">{post.data.excerpt}</p>

      <dl class="post-facts">
        <div>
          <dt>Fecha</dt>
          <dd><time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time></dd>
        </div>
        <div>
          <dt>Fuente</dt>
          <dd>{post.data.source}</dd>
        </div>
        <div>
          <dt>Enlace original</dt>
          <dd><a href={post.data.originalUrl}>{post.data.originalUrl}</a></dd>
        </div>
        <div>
          <dt>Idioma original</dt>
          <dd>{post.data.originalLanguage}</dd>
        </div>
        <div>
          <dt>Etiquetas</dt>
          <dd class="tag-list">{post.data.tags.map((tag) => <span>{tag}</span>)}</dd>
        </div>
      </dl>

      <section class="content-section">
        <h2>Resumen en español</h2>
        <p>{post.data.summary}</p>
        <Content />
      </section>

      <section class="content-section relevance">
        <h2>Por qué puede ser relevante</h2>
        <p>{post.data.relevance}</p>
      </section>

      <p class="medical-note" role="note">
        Prudencia médica: esta ficha resume información divulgativa y no debe
        interpretarse como diagnóstico, recomendación terapéutica ni sustituto de
        una consulta con profesionales sanitarios.
      </p>

      <section class="share-panel" aria-labelledby="share-title">
        <h2 id="share-title">Compartir ficha</h2>
        <div class="share-actions">
          <a href={`https://wa.me/?text=${shareText}%20${encodedUrl}`}>WhatsApp</a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}>Facebook</a>
          <a href={`https://twitter.com/intent/tweet?text=${shareText}&url=${encodedUrl}`}>X/Twitter</a>
          <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}>LinkedIn</a>
          <button type="button" data-copy-link={shareUrl}>Copiar enlace</button>
        </div>
        <p class="copy-status" aria-live="polite" data-copy-status></p>
      </section>
    </article>
  </main>

  <footer class="site-footer">
    <p>Novedades Tourette. Prototipo personal estático.</p>
  </footer>

  <script is:inline src="/novedades-tourette/share.js"></script>
</BaseLayout>
